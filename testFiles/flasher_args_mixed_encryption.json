{
  "write_flash_args": [
    "--flash-mode",
    "dio",
    "--flash-size",
    "4MB",
    "--flash-freq",
    "80m"
  ],
  "flash_settings": {
    "flash_mode": "dio",
    "flash_size": "4MB",
    "flash_freq": "80m"
  },
  "flash_files": {
    "0x1000": "bootloader/bootloader.bin",
    "0x8000": "partition_table/partition-table.bin",
    "0x10000": "blink.bin"
  },
  "bootloader": {
    "offset": "0x1000",
    "file": "bootloader/bootloader.bin",
    "encrypted": "false"
  },
  "partition-table": {
    "offset": "0x8000",
    "file": "partition_table/partition-table.bin",
    "encrypted": "false"
  },
  "app": {
    "offset": "0x10000",
    "file": "blink.bin",
    "encrypted": "true"
  },
  "extra_esptool_args": {
    "after": "hard-reset",
    "before": "default-reset",
    "stub": false,
    "chip": "esp32c3"
  }
}
